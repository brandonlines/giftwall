# Copy to .env and fill in from your Supabase project settings (API section).
# Only EXPO_PUBLIC_* vars are exposed to the app bundle. The anon key is meant
# to be public — RLS is what protects data. NEVER put the service_role key here.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Optional: crash reporting. Leave blank to disable Sentry (it no-ops).
EXPO_PUBLIC_SENTRY_DSN=

# Optional: public web origin (no trailing slash, e.g. https://giftwall.app).
# When set, invite links become https://<host>/join/<CODE> — they open the web
# app for people without the native app, and become true Universal / App Links
# once you host the association files at that host and add the domain to the
# native config (see README "Deep links"). Left blank, invites use the
# giftwall:// custom scheme, which only opens on devices that have the app.
EXPO_PUBLIC_WEB_URL=

# Optional: Amazon Associates tag (e.g. giftwall-20). When set, outbound Amazon
# product links are wrapped with ?tag=<this> so qualifying purchases earn a
# commission. NOT a secret — it appears in every affiliate URL. Left blank,
# links pass through untouched. The public-profile Edge Function reads the same
# value server-side from the AMAZON_ASSOC_TAG function secret.
EXPO_PUBLIC_AMAZON_TAG=
