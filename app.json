{
  "expo": {
    "name": "giftwall",
    "slug": "giftwall",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "giftwall",
    "userInterfaceStyle": "automatic",
    "ios": {
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.giftwall.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "102"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.giftwall.app",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "giftwall needs access to your photos so you can set a profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sharing",
      "@sentry/react-native",
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "giftwall uses the camera to scan product barcodes.",
          "recordAudioAndAndroidPermission": false
        }
      ],
      [
        "@howincodes/expo-dynamic-app-icon",
        {
          "signature": {
            "ios": "./assets/app-icons/signature.png",
            "android": {
              "foregroundImage": "./assets/app-icons/signature-foreground.png",
              "backgroundColor": "#1366D6"
            }
          },
          "birthdayBash": {
            "ios": "./assets/app-icons/birthdayBash.png",
            "android": {
              "foregroundImage": "./assets/app-icons/birthdayBash-foreground.png",
              "backgroundColor": "#E35420"
            }
          },
          "sweetBeginnings": {
            "ios": "./assets/app-icons/sweetBeginnings.png",
            "android": {
              "foregroundImage": "./assets/app-icons/sweetBeginnings-foreground.png",
              "backgroundColor": "#6E8A6E"
            }
          },
          "modernRomance": {
            "ios": "./assets/app-icons/modernRomance.png",
            "android": {
              "foregroundImage": "./assets/app-icons/modernRomance-foreground.png",
              "backgroundColor": "#3A1320"
            }
          },
          "winterFrost": {
            "ios": "./assets/app-icons/winterFrost.png",
            "android": {
              "foregroundImage": "./assets/app-icons/winterFrost-foreground.png",
              "backgroundColor": "#2B2D42"
            }
          },
          "cabinCozy": {
            "ios": "./assets/app-icons/cabinCozy.png",
            "android": {
              "foregroundImage": "./assets/app-icons/cabinCozy-foreground.png",
              "backgroundColor": "#819970"
            }
          },
          "firesideCozy": {
            "ios": "./assets/app-icons/firesideCozy.png",
            "android": {
              "foregroundImage": "./assets/app-icons/firesideCozy-foreground.png",
              "backgroundColor": "#A66F53"
            }
          },
          "northernLights": {
            "ios": "./assets/app-icons/northernLights.png",
            "android": {
              "foregroundImage": "./assets/app-icons/northernLights-foreground.png",
              "backgroundColor": "#00796B"
            }
          },
          "mountainChalet": {
            "ios": "./assets/app-icons/mountainChalet.png",
            "android": {
              "foregroundImage": "./assets/app-icons/mountainChalet-foreground.png",
              "backgroundColor": "#6D4C41"
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ed7a8fd2-4a86-440f-a34f-7eda9fb3eb6c"
      }
    },
    "owner": "blines",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ed7a8fd2-4a86-440f-a34f-7eda9fb3eb6c"
    }
  }
}