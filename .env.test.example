# Credentials for the RLS test script (npm run test:rls). Copy to .env.test.
# The service_role key bypasses RLS and can create/delete users — keep it OUT
# of the app and OUT of git (.env.test is gitignored). Use a throwaway/staging
# project, never production.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
